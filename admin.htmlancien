<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AGORA — Back-office</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Sora:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#0B0E14;
  --surface:#111620;
  --surface2:#171D2A;
  --border:#1E2738;
  --border2:#2A3347;
  --text:#E8EDF5;
  --text2:#8A95A8;
  --text3:#4A5568;
  --green:#00D68F;
  --green-dim:#003D28;
  --green-mid:#00A86B;
  --blue:#3B82F6;
  --blue-dim:#0F2040;
  --amber:#F59E0B;
  --amber-dim:#3D2800;
  --red:#EF4444;
  --red-dim:#3D0F0F;
  --purple:#8B5CF6;
  --purple-dim:#1E1040;
  --font:'Sora',sans-serif;
  --mono:'DM Mono',monospace;
  --r:8px;
  --r2:12px;
}
body{background:var(--bg);color:var(--text);font-family:var(--font);font-size:14px;line-height:1.6;min-height:100vh;display:flex;flex-direction:column}

/* GRID NOISE */
body::before{content:'';position:fixed;inset:0;background-image:radial-gradient(ellipse 80% 50% at 50% -20%,rgba(0,214,143,.08),transparent),radial-gradient(ellipse 60% 40% at 80% 80%,rgba(59,130,246,.06),transparent);pointer-events:none;z-index:0}

/* TOP NAV */
nav{position:sticky;top:0;z-index:100;background:rgba(11,14,20,.92);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);padding:0 1.5rem;display:flex;align-items:center;gap:1rem;height:56px}
.logo{display:flex;align-items:center;gap:10px;margin-right:auto}
.logo-mark{width:32px;height:32px;border-radius:8px;background:linear-gradient(135deg,var(--green),#00A86B);display:flex;align-items:center;justify-content:center}
.logo-mark svg{width:18px;height:18px}
.logo-name{font-size:15px;font-weight:600;letter-spacing:-.02em}
.logo-sub{font-size:11px;color:var(--text3);font-family:var(--mono);letter-spacing:.05em}
.nav-pill{display:flex;align-items:center;gap:6px;padding:5px 12px;border-radius:20px;font-size:12px;color:var(--text2);cursor:pointer;transition:.15s;border:1px solid transparent}
.nav-pill:hover{background:var(--surface);border-color:var(--border)}
.nav-pill.active{background:var(--green-dim);color:var(--green);border-color:rgba(0,214,143,.2)}
.nav-pill svg{width:13px;height:13px}
.avatar{width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,#1E3A5F,#2D5A8E);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;cursor:pointer;border:1px solid var(--border2)}
.badge-dot{width:7px;height:7px;border-radius:50%;background:var(--green);border:2px solid var(--bg)}

/* LAYOUT */
.layout{display:flex;flex:1;position:relative;z-index:1}
aside{width:220px;min-width:220px;border-right:1px solid var(--border);padding:1.25rem 0;display:flex;flex-direction:column;gap:.25rem;position:sticky;top:56px;height:calc(100vh - 56px);overflow-y:auto}
.aside-section{padding:0 1rem;margin-bottom:.75rem}
.aside-label{font-size:10px;font-family:var(--mono);color:var(--text3);letter-spacing:.1em;text-transform:uppercase;padding:.5rem .75rem .25rem;font-weight:500}
.aside-item{display:flex;align-items:center;gap:10px;padding:7px .75rem;border-radius:var(--r);cursor:pointer;transition:.12s;color:var(--text2);font-size:13px;position:relative}
.aside-item:hover{background:var(--surface);color:var(--text)}
.aside-item.active{background:var(--green-dim);color:var(--green)}
.aside-item svg{width:15px;height:15px;flex-shrink:0}
.aside-item .count{margin-left:auto;font-family:var(--mono);font-size:11px;padding:1px 6px;border-radius:10px;background:var(--surface2)}
.aside-item.active .count{background:rgba(0,214,143,.15);color:var(--green)}

main{flex:1;padding:1.75rem;overflow-x:hidden}

/* SECTION TITLES */
.page-title{font-size:22px;font-weight:600;letter-spacing:-.03em;margin-bottom:.25rem}
.page-sub{font-size:13px;color:var(--text2);margin-bottom:1.5rem}

/* METRIC CARDS */
.metrics{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:1.5rem}
.metric{background:var(--surface);border:1px solid var(--border);border-radius:var(--r2);padding:1.125rem 1.25rem;position:relative;overflow:hidden;cursor:default;transition:.2s}
.metric:hover{border-color:var(--border2);transform:translateY(-1px)}
.metric::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;border-radius:2px 2px 0 0}
.metric.green::before{background:linear-gradient(90deg,var(--green),transparent)}
.metric.blue::before{background:linear-gradient(90deg,var(--blue),transparent)}
.metric.amber::before{background:linear-gradient(90deg,var(--amber),transparent)}
.metric.purple::before{background:linear-gradient(90deg,var(--purple),transparent)}
.metric-label{font-size:11px;color:var(--text3);font-family:var(--mono);letter-spacing:.05em;text-transform:uppercase;margin-bottom:.5rem}
.metric-value{font-size:28px;font-weight:600;letter-spacing:-.04em;line-height:1}
.metric-value.green{color:var(--green)}
.metric-value.blue{color:var(--blue)}
.metric-value.amber{color:var(--amber)}
.metric-value.purple{color:var(--purple)}
.metric-sub{font-size:11px;color:var(--text3);margin-top:.375rem}
.metric-icon{position:absolute;top:1rem;right:1rem;opacity:.12}
.metric-icon svg{width:32px;height:32px}

/* GRID 2 COL */
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:1.5rem}
.grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:1.5rem}

/* CARDS */
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r2);padding:1.25rem}
.card-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem}
.card-title{font-size:13px;font-weight:500;letter-spacing:-.01em}
.card-action{font-size:11px;color:var(--text3);cursor:pointer;font-family:var(--mono);padding:4px 8px;border:1px solid var(--border);border-radius:6px;transition:.12s}
.card-action:hover{color:var(--text);border-color:var(--border2)}

/* PIPELINE */
.pipeline{display:flex;flex-direction:column;gap:6px}
.pipe-row{display:flex;align-items:center;gap:10px}
.pipe-label{font-size:12px;color:var(--text2);width:160px;flex-shrink:0}
.pipe-bar-wrap{flex:1;height:6px;background:var(--surface2);border-radius:3px;overflow:hidden}
.pipe-bar{height:6px;border-radius:3px;transition:width .6s ease}
.pipe-count{font-family:var(--mono);font-size:11px;color:var(--text3);min-width:30px;text-align:right}
.pipe-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}

/* SEGMENT BARS */
.seg-list{display:flex;flex-direction:column;gap:10px}
.seg-item{}
.seg-head{display:flex;justify-content:space-between;margin-bottom:4px}
.seg-name{font-size:12px;color:var(--text2)}
.seg-nums{font-family:var(--mono);font-size:11px;color:var(--text3)}
.seg-bar-wrap{height:5px;background:var(--surface2);border-radius:3px;overflow:hidden}
.seg-bar{height:5px;border-radius:3px}
.arr-row{display:flex;justify-content:space-between;margin-top:1rem;padding-top:.875rem;border-top:1px solid var(--border)}
.arr-label{font-size:11px;color:var(--text3)}
.arr-value{font-family:var(--mono);font-size:13px;color:var(--green);font-weight:500}

/* ALERT CARD */
.alert-list{display:flex;flex-direction:column;gap:8px}
.alert-item{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:var(--r);border:1px solid var(--border);background:var(--surface2);cursor:pointer;transition:.12s}
.alert-item:hover{border-color:var(--border2)}
.alert-icon{width:28px;height:28px;border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.alert-icon svg{width:14px;height:14px}
.alert-title{font-size:12px;font-weight:500}
.alert-sub{font-size:11px;color:var(--text3)}
.alert-arrow{margin-left:auto;color:var(--text3);font-size:14px}

/* LEGAL SECTION */
.legal-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.legal-item{padding:10px 12px;border-radius:var(--r);border:1px solid var(--border);background:var(--surface2);display:flex;align-items:center;gap:10px;cursor:pointer;transition:.12s}
.legal-item:hover{border-color:var(--border2)}
.legal-icon{width:28px;height:28px;border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0;background:var(--surface)}
.legal-icon svg{width:14px;height:14px;color:var(--text2)}
.legal-name{font-size:12px;font-weight:500}
.legal-desc{font-size:11px;color:var(--text3)}
.legal-status{margin-left:auto;width:7px;height:7px;border-radius:50%;flex-shrink:0}

/* RELANCES */
.relance-empty{text-align:center;padding:2rem 1rem}
.relance-empty-icon{font-size:28px;margin-bottom:.5rem;opacity:.3}
.relance-empty-text{font-size:12px;color:var(--text3)}

/* AUDIT LOG */
.log-list{display:flex;flex-direction:column}
.log-item{display:flex;align-items:flex-start;gap:10px;padding:8px 0;border-bottom:1px solid var(--border)}
.log-item:last-child{border-bottom:none}
.log-time{font-family:var(--mono);font-size:10px;color:var(--text3);min-width:55px;padding-top:2px}
.log-dot{width:7px;height:7px;border-radius:50%;margin-top:5px;flex-shrink:0}
.log-text{font-size:12px;color:var(--text2);line-height:1.5}
.log-text strong{color:var(--text);font-weight:500}

/* BTN */
.btn{display:inline-flex;align-items:center;gap:6px;padding:6px 14px;border-radius:var(--r);font-size:12px;font-family:var(--font);font-weight:500;cursor:pointer;transition:.12s;border:none}
.btn-green{background:var(--green-dim);color:var(--green);border:1px solid rgba(0,214,143,.2)}
.btn-green:hover{background:rgba(0,214,143,.15)}
.btn-ghost{background:transparent;color:var(--text2);border:1px solid var(--border)}
.btn-ghost:hover{background:var(--surface2);color:var(--text)}
.btn svg{width:12px;height:12px}

/* STATUS PILLS */
.pill{display:inline-flex;align-items:center;gap:4px;padding:2px 8px;border-radius:10px;font-size:11px;font-family:var(--mono);font-weight:500}
.pill-green{background:var(--green-dim);color:var(--green)}
.pill-amber{background:var(--amber-dim);color:var(--amber)}
.pill-red{background:var(--red-dim);color:var(--red)}
.pill-blue{background:var(--blue-dim);color:var(--blue)}
.pill-gray{background:var(--surface2);color:var(--text3)}

/* SECURITY BANNER */
.sec-banner{background:var(--blue-dim);border:1px solid rgba(59,130,246,.2);border-radius:var(--r2);padding:.875rem 1.125rem;display:flex;align-items:center;gap:12px;margin-bottom:1.5rem}
.sec-banner svg{width:16px;height:16px;color:var(--blue);flex-shrink:0}
.sec-banner-text{font-size:12px;color:rgba(147,197,253,.8)}
.sec-banner-text strong{color:#93C5FD}
.sec-banner-right{margin-left:auto;font-family:var(--mono);font-size:11px;color:var(--blue)}

/* ANIMATIONS */
@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.metrics .metric{animation:fadeUp .4s ease both}
.metric:nth-child(1){animation-delay:.05s}
.metric:nth-child(2){animation-delay:.1s}
.metric:nth-child(3){animation-delay:.15s}
.metric:nth-child(4){animation-delay:.2s}
.card{animation:fadeUp .4s ease .2s both}

/* SCROLLBAR */
::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}

/* SECTION TABS */
.tabs{display:flex;gap:2px;margin-bottom:1.5rem;background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:3px}
.tab{padding:6px 14px;border-radius:6px;font-size:12px;font-weight:500;cursor:pointer;color:var(--text3);transition:.12s}
.tab.active{background:var(--surface2);color:var(--text);box-shadow:0 1px 3px rgba(0,0,0,.3)}
.tab:hover:not(.active){color:var(--text2)}
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="logo">
    <div class="logo-mark">
      <svg viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="7" stroke="white" stroke-width="1.5"/><path d="M6 9h6M9 6v6" stroke="white" stroke-width="1.5" stroke-linecap="round"/></svg>
    </div>
    <div>
      <div class="logo-name">AGORA</div>
      <div class="logo-sub">back-office</div>
    </div>
  </div>

  <div class="nav-pill active">
    <svg viewBox="0 0 14 14" fill="none"><rect x="1" y="1" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.2"/><rect x="8" y="1" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.2"/><rect x="1" y="8" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.2"/><rect x="8" y="8" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.2"/></svg>
    Dashboard
  </div>
  <div class="nav-pill">
    <svg viewBox="0 0 14 14" fill="none"><circle cx="7" cy="5" r="2.5" stroke="currentColor" stroke-width="1.2"/><path d="M2 12c0-2.76 2.24-5 5-5s5 2.24 5 5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
    Communes
  </div>
  <div class="nav-pill">
    <svg viewBox="0 0 14 14" fill="none"><rect x="1" y="3" width="12" height="9" rx="1.5" stroke="currentColor" stroke-width="1.2"/><path d="M4 3V2.5a1 1 0 0 1 2 0V3M8 3V2.5a1 1 0 0 1 2 0V3" stroke="currentColor" stroke-width="1.2"/></svg>
    Licences
  </div>
  <div class="nav-pill">
    <svg viewBox="0 0 14 14" fill="none"><path d="M7 1v2M7 11v2M1 7h2M11 7h2M3 3l1.5 1.5M9.5 9.5L11 11M3 11l1.5-1.5M9.5 4.5L11 3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
    Automatisations
  </div>

  <div style="position:relative;margin-left:.5rem">
    <div class="avatar">Z</div>
    <div class="badge-dot" style="position:absolute;bottom:0;right:0"></div>
  </div>
</nav>

<div class="layout">

<!-- SIDEBAR -->
<aside>
  <div class="aside-label">Vue globale</div>
  <div class="aside-item active">
    <svg viewBox="0 0 15 15" fill="none"><rect x="1" y="1" width="5.5" height="5.5" rx="1" stroke="currentColor" stroke-width="1.2"/><rect x="8.5" y="1" width="5.5" height="5.5" rx="1" stroke="currentColor" stroke-width="1.2"/><rect x="1" y="8.5" width="5.5" height="5.5" rx="1" stroke="currentColor" stroke-width="1.2"/><rect x="8.5" y="8.5" width="5.5" height="5.5" rx="1" stroke="currentColor" stroke-width="1.2"/></svg>
    Dashboard
    <span class="count" style="background:var(--green-dim);color:var(--green)">live</span>
  </div>
  <div class="aside-item">
    <svg viewBox="0 0 15 15" fill="none"><circle cx="7.5" cy="5" r="2.5" stroke="currentColor" stroke-width="1.2"/><path d="M2 13c0-3.04 2.46-5.5 5.5-5.5S13 9.96 13 13" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
    Communes
    <span class="count">771</span>
  </div>
  <div class="aside-item">
    <svg viewBox="0 0 15 15" fill="none"><rect x="1.5" y="3" width="12" height="10" rx="1.5" stroke="currentColor" stroke-width="1.2"/><path d="M4.5 3V2a1 1 0 0 1 2 0v1M8.5 3V2a1 1 0 0 1 2 0v1" stroke="currentColor" stroke-width="1.2"/><path d="M4 8h7M4 11h4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
    Licences
    <span class="count">0</span>
  </div>

  <div class="aside-label" style="margin-top:.5rem">Prospection</div>
  <div class="aside-item">
    <svg viewBox="0 0 15 15" fill="none"><path d="M2 12L5.5 7l3 3L12 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    Pipeline
    <span class="count">0</span>
  </div>
  <div class="aside-item">
    <svg viewBox="0 0 15 15" fill="none"><circle cx="7.5" cy="7.5" r="6" stroke="currentColor" stroke-width="1.2"/><path d="M7.5 4v4l2.5 2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
    Relances
    <span class="count">0</span>
  </div>
  <div class="aside-item">
    <svg viewBox="0 0 15 15" fill="none"><path d="M2 4h11M2 7.5h8M2 11h6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
    Interactions
    <span class="count">0</span>
  </div>

  <div class="aside-label" style="margin-top:.5rem">Finances</div>
  <div class="aside-item">
    <svg viewBox="0 0 15 15" fill="none"><path d="M7.5 1.5v1M7.5 12.5v1M3 7.5H2M13 7.5h-1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><circle cx="7.5" cy="7.5" r="3.5" stroke="currentColor" stroke-width="1.2"/><path d="M6.5 7.5c0-.55.45-1 1-1s1 .45 1 1-.45 1-1 1" stroke="currentColor" stroke-width="1.2"/></svg>
    Revenus
  </div>
  <div class="aside-item">
    <svg viewBox="0 0 15 15" fill="none"><path d="M3 2h9a1 1 0 0 1 1 1v9a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1z" stroke="currentColor" stroke-width="1.2"/><path d="M5 6h5M5 9h3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
    Factures
  </div>

  <div class="aside-label" style="margin-top:.5rem">Légal & Sécurité</div>
  <div class="aside-item">
    <svg viewBox="0 0 15 15" fill="none"><path d="M7.5 1L2 3.5v4c0 3.5 2.5 5.5 5.5 6.5 3-1 5.5-3 5.5-6.5v-4L7.5 1z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/></svg>
    Conformité RGPD
  </div>
  <div class="aside-item">
    <svg viewBox="0 0 15 15" fill="none"><path d="M2 4h11M2 7.5h11M2 11h11" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
    Journal d'audit
  </div>

  <div style="margin-top:auto;padding:.75rem 1rem;border-top:1px solid var(--border)">
    <div style="display:flex;align-items:center;gap:8px">
      <div style="width:7px;height:7px;border-radius:50%;background:var(--green)"></div>
      <span style="font-size:11px;color:var(--text3);font-family:var(--mono)">Supabase connecté</span>
    </div>
    <div style="display:flex;align-items:center;gap:8px;margin-top:5px">
      <div style="width:7px;height:7px;border-radius:50%;background:var(--green)"></div>
      <span style="font-size:11px;color:var(--text3);font-family:var(--mono)">Stripe connecté</span>
    </div>
  </div>
</aside>

<!-- MAIN -->
<main>

  <!-- SECURITY BANNER -->
  <div class="sec-banner">
    <svg viewBox="0 0 16 16" fill="none"><path d="M8 1L2 3.5v4c0 3.5 2.5 5.5 6 6.5 3.5-1 6-3 6-6.5v-4L8 1z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/><path d="M5.5 8l2 2 3-3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    <div class="sec-banner-text">
      <strong>Session sécurisée</strong> — Toutes les actions sont journalisées. Données hébergées UE (Supabase eu-west). Chiffrement TLS 1.3.
    </div>
    <div class="sec-banner-right">Zeko · admin</div>
  </div>

  <!-- TITRE -->
  <div class="page-title">Tableau de bord</div>
  <div class="page-sub">Vue en temps réel — plateforme-agora.fr · 771 communes cibles · Somme (80)</div>

  <!-- METRICS -->
  <div class="metrics">
    <div class="metric green">
      <div class="metric-icon"><svg viewBox="0 0 32 32" fill="none"><circle cx="16" cy="16" r="14" stroke="currentColor" stroke-width="1.5"/></svg></div>
      <div class="metric-label">Communes actives</div>
      <div class="metric-value green">0</div>
      <div class="metric-sub">sur 771 ciblées · 0%</div>
    </div>
    <div class="metric blue">
      <div class="metric-icon"><svg viewBox="0 0 32 32" fill="none"><path d="M16 4v8M16 20v8M4 16h8M20 16h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></div>
      <div class="metric-label">ARR actuel</div>
      <div class="metric-value blue">0 €</div>
      <div class="metric-sub">potentiel max · 636 710 €</div>
    </div>
    <div class="metric amber">
      <div class="metric-icon"><svg viewBox="0 0 32 32" fill="none"><circle cx="16" cy="12" r="6" stroke="currentColor" stroke-width="1.5"/><path d="M6 28c0-5.52 4.48-10 10-10s10 4.48 10 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></div>
      <div class="metric-label">Pipeline actif</div>
      <div class="metric-value amber">0</div>
      <div class="metric-sub">communes en prospection</div>
    </div>
    <div class="metric purple">
      <div class="metric-icon"><svg viewBox="0 0 32 32" fill="none"><circle cx="16" cy="16" r="8" stroke="currentColor" stroke-width="1.5"/><path d="M16 10v6l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></div>
      <div class="metric-label">Relances J+0</div>
      <div class="metric-value purple">0</div>
      <div class="metric-sub">à effectuer aujourd'hui</div>
    </div>
  </div>

  <!-- ROW 1 -->
  <div class="grid2">

    <div class="card">
      <div class="card-header">
        <div class="card-title">Pipeline de prospection</div>
        <button class="card-action">Voir tout →</button>
      </div>
      <div class="pipeline">
        <div class="pipe-row">
          <div class="pipe-dot" style="background:var(--text3)"></div>
          <div class="pipe-label">Non contacté</div>
          <div class="pipe-bar-wrap"><div class="pipe-bar" style="width:100%;background:var(--border2)"></div></div>
          <div class="pipe-count">771</div>
        </div>
        <div class="pipe-row">
          <div class="pipe-dot" style="background:var(--blue)"></div>
          <div class="pipe-label">Contacté</div>
          <div class="pipe-bar-wrap"><div class="pipe-bar" style="width:0%;background:var(--blue)"></div></div>
          <div class="pipe-count">0</div>
        </div>
        <div class="pipe-row">
          <div class="pipe-dot" style="background:var(--amber)"></div>
          <div class="pipe-label">Intéressé</div>
          <div class="pipe-bar-wrap"><div class="pipe-bar" style="width:0%;background:var(--amber)"></div></div>
          <div class="pipe-count">0</div>
        </div>
        <div class="pipe-row">
          <div class="pipe-dot" style="background:var(--purple)"></div>
          <div class="pipe-label">Proposition envoyée</div>
          <div class="pipe-bar-wrap"><div class="pipe-bar" style="width:0%;background:var(--purple)"></div></div>
          <div class="pipe-count">0</div>
        </div>
        <div class="pipe-row">
          <div class="pipe-dot" style="background:var(--green)"></div>
          <div class="pipe-label">Client ✓</div>
          <div class="pipe-bar-wrap"><div class="pipe-bar" style="width:0%;background:var(--green)"></div></div>
          <div class="pipe-count">0</div>
        </div>
        <div class="pipe-row">
          <div class="pipe-dot" style="background:var(--red)"></div>
          <div class="pipe-label">Perdu</div>
          <div class="pipe-bar-wrap"><div class="pipe-bar" style="width:0%;background:var(--red)"></div></div>
          <div class="pipe-count">0</div>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <div class="card-title">Licences par segment</div>
        <button class="card-action">Gérer →</button>
      </div>
      <div class="seg-list">
        <div class="seg-item">
          <div class="seg-head">
            <span class="seg-name">Hameau · 590 €/an</span>
            <span class="seg-nums">0 / 540</span>
          </div>
          <div class="seg-bar-wrap"><div class="seg-bar" style="width:0%;background:var(--blue)"></div></div>
        </div>
        <div class="seg-item">
          <div class="seg-head">
            <span class="seg-name">Village · 990 €/an</span>
            <span class="seg-nums">0 / 197</span>
          </div>
          <div class="seg-bar-wrap"><div class="seg-bar" style="width:0%;background:var(--purple)"></div></div>
        </div>
        <div class="seg-item">
          <div class="seg-head">
            <span class="seg-name">Bourg · 1 790 €/an</span>
            <span class="seg-nums">0 / 25</span>
          </div>
          <div class="seg-bar-wrap"><div class="seg-bar" style="width:0%;background:var(--amber)"></div></div>
        </div>
        <div class="seg-item">
          <div class="seg-head">
            <span class="seg-name">Ville · sur devis</span>
            <span class="seg-nums">0 / 9</span>
          </div>
          <div class="seg-bar-wrap"><div class="seg-bar" style="width:0%;background:var(--green)"></div></div>
        </div>
        <div class="arr-row">
          <span class="arr-label">ARR potentiel max</span>
          <span class="arr-value">636 710 €</span>
        </div>
      </div>
    </div>

  </div>

  <!-- ROW 2 -->
  <div class="grid3">

    <div class="card">
      <div class="card-header">
        <div class="card-title">Relances du jour</div>
        <button class="btn btn-green">
          <svg viewBox="0 0 12 12" fill="none"><path d="M6 1v10M1 6h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          Ajouter
        </button>
      </div>
      <div class="relance-empty">
        <div class="relance-empty-icon">○</div>
        <div class="relance-empty-text">Aucune relance planifiée<br>Commence à prospecter</div>
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <div class="card-title">Légal & conformité</div>
      </div>
      <div class="legal-grid">
        <div class="legal-item">
          <div class="legal-icon">
            <svg viewBox="0 0 14 14" fill="none"><path d="M7 1L2 3v4c0 3 2 5 5 6 3-1 5-3 5-6V3L7 1z" stroke="currentColor" stroke-width="1.1"/></svg>
          </div>
          <div>
            <div class="legal-name">RGPD</div>
            <div class="legal-desc">Politique rédigée</div>
          </div>
          <div class="legal-status" style="background:var(--amber)"></div>
        </div>
        <div class="legal-item">
          <div class="legal-icon">
            <svg viewBox="0 0 14 14" fill="none"><path d="M3 2h8a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1z" stroke="currentColor" stroke-width="1.1"/><path d="M4.5 7l2 2 3-3" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>
          </div>
          <div>
            <div class="legal-name">CGV B2G</div>
            <div class="legal-desc">À rédiger</div>
          </div>
          <div class="legal-status" style="background:var(--red)"></div>
        </div>
        <div class="legal-item">
          <div class="legal-icon">
            <svg viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="5.5" stroke="currentColor" stroke-width="1.1"/><path d="M7 4.5v3l2 2" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>
          </div>
          <div>
            <div class="legal-name">RGAA</div>
            <div class="legal-desc">Déclaration</div>
          </div>
          <div class="legal-status" style="background:var(--red)"></div>
        </div>
        <div class="legal-item">
          <div class="legal-icon">
            <svg viewBox="0 0 14 14" fill="none"><path d="M2 4h10M2 7h10M2 10h6" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>
          </div>
          <div>
            <div class="legal-name">Factures</div>
            <div class="legal-desc">Config Stripe</div>
          </div>
          <div class="legal-status" style="background:var(--amber)"></div>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <div class="card-title">Journal d'audit</div>
        <button class="card-action">Tout voir →</button>
      </div>
      <div class="log-list">
        <div class="log-item">
          <div class="log-time">maintenant</div>
          <div class="log-dot" style="background:var(--green)"></div>
          <div class="log-text"><strong>Connexion admin</strong> — session ouverte</div>
        </div>
        <div class="log-item">
          <div class="log-time">00:00</div>
          <div class="log-dot" style="background:var(--blue)"></div>
          <div class="log-text"><strong>Import</strong> — 771 communes chargées</div>
        </div>
        <div class="log-item">
          <div class="log-time">00:00</div>
          <div class="log-dot" style="background:var(--blue)"></div>
          <div class="log-text"><strong>RLS activé</strong> — lecture publique communes</div>
        </div>
        <div class="log-item">
          <div class="log-time">00:00</div>
          <div class="log-dot" style="background:var(--purple)"></div>
          <div class="log-text"><strong>Webhook Stripe</strong> — Edge Function déployée</div>
        </div>
        <div class="log-item">
          <div class="log-time">00:00</div>
          <div class="log-dot" style="background:var(--green)"></div>
          <div class="log-text"><strong>DNS propagé</strong> — plateforme-agora.fr live</div>
        </div>
      </div>
    </div>

  </div>

  <!-- ALERTES -->
  <div class="card" style="margin-bottom:1.5rem">
    <div class="card-header">
      <div class="card-title">Actions prioritaires</div>
      <span class="pill pill-amber">3 en attente</span>
    </div>
    <div class="alert-list">
      <div class="alert-item">
        <div class="alert-icon" style="background:var(--red-dim)">
          <svg viewBox="0 0 14 14" fill="none"><path d="M7 1L1 12h12L7 1z" stroke="#EF4444" stroke-width="1.2" stroke-linejoin="round"/><path d="M7 5v4M7 10.5v.5" stroke="#EF4444" stroke-width="1.2" stroke-linecap="round"/></svg>
        </div>
        <div>
          <div class="alert-title">CGV B2G à rédiger</div>
          <div class="alert-sub">Obligatoire avant toute vente à une collectivité</div>
        </div>
        <span class="pill pill-red" style="margin-left:auto;margin-right:8px">urgent</span>
        <div class="alert-arrow">→</div>
      </div>
      <div class="alert-item">
        <div class="alert-icon" style="background:var(--red-dim)">
          <svg viewBox="0 0 14 14" fill="none"><path d="M7 1L2 3v4c0 3 2 5 5 6 3-1 5-3 5-6V3L7 1z" stroke="#EF4444" stroke-width="1.2"/></svg>
        </div>
        <div>
          <div class="alert-title">Déclaration RGAA à publier</div>
          <div class="alert-sub">Accessibilité obligatoire pour les outils vendus aux mairies</div>
        </div>
        <span class="pill pill-red" style="margin-left:auto;margin-right:8px">urgent</span>
        <div class="alert-arrow">→</div>
      </div>
      <div class="alert-item">
        <div class="alert-icon" style="background:var(--amber-dim)">
          <svg viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="5.5" stroke="#F59E0B" stroke-width="1.2"/><path d="M7 4v3l2 2" stroke="#F59E0B" stroke-width="1.2" stroke-linecap="round"/></svg>
        </div>
        <div>
          <div class="alert-title">Test end-to-end à valider</div>
          <div class="alert-sub">Tester la chaîne complète avec une commune fictive</div>
        </div>
        <span class="pill pill-amber" style="margin-left:auto;margin-right:8px">en cours</span>
        <div class="alert-arrow">→</div>
      </div>
    </div>
  </div>

</main>
</div>
</body>
</html>
